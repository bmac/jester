{
  "name": "jester",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "test": "vitest",
    "e2e": "NODE_OPTIONS='--import tsx/esm' cucumber-js --import features/support/steps.ts",
    "specflow": "NODE_OPTIONS='--import tsx/esm' cucumber-js --import features/support/steps-specflow.ts",
    "playwright": "playwright test e2e",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/server/index.js",
    "prettier": "prettier --write .",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.3",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "html-escaper": "^3.0.3",
    "isbot": "^5.1.39",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.23.8",
    "zodix": "^0.4.4"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@mswjs/interceptors": "^0.41.4",
    "@playwright/test": "^1.59.1",
    "@remix-run/dev": "^2.17.4",
    "@remix-run/testing": "^2.17.4",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/html-escaper": "^3.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cucumber-tsflow": "^4.6.1",
    "eslint": "^9.24.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.24.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.0",
    "vcr-test": "^1.4.0",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
