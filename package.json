{
  "name": "jester",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "test": "vitest",
    "e2e": "NODE_OPTIONS='--import tsx/esm' cucumber-js --import features/support/steps.ts",
    "specflow": "NODE_OPTIONS='--import tsx/esm' cucumber-js --import features/support/steps-specflow.ts",
    "playwright": "playwright test e2e",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "react-router-serve ./build/server/index.js",
    "prettier": "prettier --write .",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.3",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "html-escaper": "^3.0.3",
    "isbot": "^5.1.39",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@eslint/js": "^9.39.4",
    "@mswjs/interceptors": "^0.41.4",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.14.1",
    "@react-router/fs-routes": "^7.14.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/html-escaper": "^3.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/react-router": "^1.2.6",
    "@vitejs/plugin-react": "^6.0.1",
    "cucumber-tsflow": "^4.6.1",
    "eslint": "^9.24.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.24.0",
    "vcr-test": "^1.4.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "unrs-resolver"],
    "overrides": {
      "@vercel/static-config>ajv": "^8.18.0",
      "yaml@<2.8.3": "^2.8.3"
    }
  }
}
